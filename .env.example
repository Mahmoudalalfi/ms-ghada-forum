PORT=3000
DATABASE_URL=postgresql://username:password@host:5432/database_name

# Set to false if your Postgres server does not require SSL.
DB_SSL=true

# Teacher dashboard basic auth credentials
ADMIN_USERNAME=teacher
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=replace-with-long-random-secret
OTP_SECRET=replace-with-long-random-secret
OTP_TTL_MINUTES=10
MIN_SECONDS_BETWEEN_SUBMITS=8

# Secret teacher-only URL path
# Example: /teacher-portal-ghada-9x2m7
ADMIN_DASHBOARD_PATH=/teacher-portal-ghada

# Optional host allow-list (comma-separated, no protocol).
# Example: ALLOWED_HOSTS=localhost,127.0.0.1,mydomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional Twilio SMS provider for OTP (recommended in production)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
